# .gitignore — CreatorConnect Monorepo

# ── Node / npm ─────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js

# ── Environment secrets ────────────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# ── Build artifacts ────────────────────────────────────────────────────────────
dist/
build/
.next/
out/

# ── Python ─────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg-info/
.eggs/
venv/
env/
.venv/

# ── macOS ──────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon?
Thumbs.db

# ── Uploads (local dev only — use Cloudinary/S3 in production) ─────────────────
apps/backend-core/uploads/
uploads/

# ── Deployment configs ─────────────────────────────────────────────────────────
.vercel/

# ── Editor ─────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
